<%- layout('layouts/boilerplate') %>

    <section class="hero-parallax">
        <div class="hero-overlay"></div>

        <div class="hero-content">
            <h1 class="display-4 fw-bold mb-4">Welcome to <span id="typing-text"></span><span class="cursor">|</span>
            </h1>
            <p class="lead mb-4">Find your perfect stay from around the world</p>
            <a href="/listings" class="btn btn-light btn-lg">Explore Listings</a>
        </div>
    </section>

    <div class="container py-5">
        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-house-heart-fill text-primary fs-1 mb-3"></i>
                        <h5 class="card-title">Unique Properties</h5>
                        <p class="card-text">Discover one-of-a-kind homes and experiences</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-shield-check text-success fs-1 mb-3"></i>
                        <h5 class="card-title">Safe & Secure</h5>
                        <p class="card-text">Book with confidence on our trusted platform</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-star-fill text-warning fs-1 mb-3"></i>
                        <h5 class="card-title">Verified Reviews</h5>
                        <p class="card-text">Read authentic reviews from real guests</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>

    <!-- Typewriter Effect Script & Styles -->
    <style>
        .cursor {
            display: inline-block;
            width: 3px;
            animation: blink 0.7s infinite;
        }

        @keyframes blink {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0;
            }

            100% {
                opacity: 1;
            }
        }
    </style>

    <script>
        const text = "StayVista";
        const typingTextElement = document.getElementById("typing-text");
        let i = 0;

        function typeWriter() {
            if (i < text.length) {
                typingTextElement.innerHTML += text.charAt(i);
                i++;
                setTimeout(typeWriter, 150);
            } else {
                // Wait briefly, clear the text, and restart the animation
                setTimeout(() => {
                    typingTextElement.innerHTML = '';
                    i = 0;
                    typeWriter();
                }, 2000); // 2-second pause before looping
            }
        }

        // Start typing on load
        window.onload = typeWriter;
    </script>