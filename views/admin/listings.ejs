<%- layout('layouts/boilerplate') %>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Listings</h2>
        <a href="/admin/dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>
    
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Owner</th>
                    <th>Location</th>
                    <th>Price</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% listings.forEach(listing => { %>
                    <tr>
                        <td><%= listing.title %></td>
                        <td><%= listing.owner.username %></td>
                        <td><%= listing.location %>, <%= listing.country %></td>
                        <td>$<%= listing.price %></td>
                        <td><%= new Date(listing.createdAt).toLocaleDateString() %></td>
                        <td>
                            <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-outline-primary">View</a>
                            <form action="/admin/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
                                <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this listing?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    
    <% if(listings.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-house text-muted fs-1"></i>
            <h3 class="mt-3">No listings found</h3>
            <p class="text-muted">There are no listings in the system yet.</p>
        </div>
    <% } %>
</div>
