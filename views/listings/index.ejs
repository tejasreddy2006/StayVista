<%- layout('layouts/boilerplate') %>

    <div class="container">
        <div class="row mb-4">
            <div class="col">
                <h1>All Listings</h1>
                <p class="text-muted">Find your perfect stay from our collection of properties</p>
            </div>
            <% if(currentUser && currentUser.role==='admin' ) { %>
                <div class="col text-end">
                    <a href="/listings/new" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add New Listing
                    </a>
                </div>
                <% } %>
        </div>

        <div class="row">
            <% for(let listing of listings) { %>
                <div class="col-md-4 mb-4">
                    <div class="card listing-card h-100 shadow-sm">
                        <img src="<%= listing.image %>" class="card-img-top" alt="<%= listing.title %>">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <%= listing.title %>
                            </h5>
                            <p class="card-text text-muted small">
                                <i class="bi bi-geo-alt"></i>
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                            <p class="card-text">
                                <%= listing.description.substring(0, 100) %>...
                            </p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="h5 text-primary">$<%= listing.price %></span>
                                    <span class="text-muted">/night</span>
                                </div>
                                <a href="/listings/<%= listing._id %>" class="btn btn-outline-primary btn-sm mt-2">View
                                    Details</a>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
        </div>

        <% if(listings.length===0) { %>
            <div class="text-center py-5">
                <i class="bi bi-house text-muted fs-1"></i>
                <h3 class="mt-3">No listings yet</h3>
                <p class="text-muted">Be the first to add a listing!</p>
                <% if(currentUser) { %>
                    <a href="/listings/new" class="btn btn-primary">Create Listing</a>
                    <% } %>
            </div>
            <% } %>
    </div>