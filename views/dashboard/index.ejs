<%- layout('layouts/boilerplate') %>

    <div class="container">
        <h2 class="mb-4">My Dashboard</h2>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="bi bi-house-door text-primary fs-1"></i>
                        <h5 class="card-title mt-2">My Listings</h5>
                        <p class="card-text fs-3 fw-bold" id="myListingsCount">
                            <%= listingsCount || 0 %>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="bi bi-calendar-check text-success fs-1"></i>
                        <h5 class="card-title mt-2">My Bookings</h5>
                        <p class="card-text fs-3 fw-bold" id="myBookingsCount">
                            <%= bookingsCount || 0 %>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="bi bi-star text-warning fs-1"></i>
                        <h5 class="card-title mt-2">My Reviews</h5>
                        <p class="card-text fs-3 fw-bold" id="myReviewsCount">
                            <%= reviewsCount || 0 %>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="bi bi-wallet2 text-info fs-1"></i>
                        <h5 class="card-title mt-2">Total Spent</h5>
                        <p class="card-text fs-3 fw-bold">
                            ₹<%= totalSpent.toLocaleString("en-IN") %>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <h4>Recent Bookings</h4>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Property</th>
                                <th>Check-in</th>
                                <th>Check-out</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="recentBookings">
                            <% if (recentBookings && recentBookings.length> 0) { %>
                                <% recentBookings.forEach(booking=> { %>
                                    <tr>
                                        <td>
                                            <%= booking.listing ? booking.listing.title : 'Deleted Listing' %>
                                        </td>
                                        <td>
                                            <%= new Date(booking.checkInDate).toLocaleDateString() %>
                                        </td>
                                        <td>
                                            <%= new Date(booking.checkOutDate).toLocaleDateString() %>
                                        </td>
                                        <td>₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                                        </td>
                                        <td>
                                            <% if (booking.paymentStatus==='paid' ) { %>
                                                <span class="badge bg-success">Paid</span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <% if (booking.paymentStatus==='pending' ) { %>
                                                <div class="d-flex gap-2">
                                                    <form action="/bookings/<%= booking._id %>/pay" method="POST"
                                                        class="d-inline">
                                                        <button class="btn btn-sm btn-success">Pay Now</button>
                                                    </form>
                                                    <form action="/bookings/<%= booking._id %>?_method=DELETE"
                                                        method="POST" class="d-inline"
                                                        onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                                        <button class="btn btn-sm btn-danger">Cancel Booking</button>
                                                    </form>
                                                </div>
                                                <% } else { %>
                                                    <span class="text-success"><i class="bi bi-check-circle-fill"></i>
                                                        Payment Completed</span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center text-muted">No bookings yet</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-md-6">
                <h4>Quick Actions</h4>
                <div class="d-grid gap-2">
                    <% if(currentUser && currentUser.role==='admin' ) { %>
                        <a href="/listings/new" class="btn btn-primary">Create New Listing</a>
                        <% } %>
                            <a href="/listings" class="btn btn-outline-primary">Browse All Listings</a>
                            <% if(currentUser && currentUser.role==='admin' ) { %>
                                <a href="/admin/dashboard" class="btn btn-outline-danger">Admin Dashboard</a>
                                <% } %>
                </div>
            </div>
        </div>
    </div>