<%- layout('layouts/boilerplate') %>

<div class="container">
    <h2 class="mb-4">My Bookings</h2>
    
    <div class="row">
        <% bookings.forEach(booking => { %>
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><%= booking.listing.title %></h5>
                        <p class="text-muted">
                            <i class="bi bi-geo-alt"></i> <%= booking.listing.location %>, <%= booking.listing.country %>
                        </p>
                        <div class="row">
                            <div class="col-6">
                                <strong>Check-in:</strong><br>
                                <%= new Date(booking.checkInDate).toLocaleDateString() %>
                            </div>
                            <div class="col-6">
                                <strong>Check-out:</strong><br>
                                <%= new Date(booking.checkOutDate).toLocaleDateString() %>
                            </div>
                        </div>
                        <div class="mt-3">
                            <span class="h4 text-primary">₹<%= booking.totalPrice %></span>
                        </div>
                        <div class="mt-3">
                            <small class="text-muted">
                                Booked on <%= new Date(booking.createdAt).toLocaleDateString() %>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    
    <% if(bookings.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted fs-1"></i>
            <h3 class="mt-3">No bookings yet</h3>
            <p class="text-muted">Start exploring and book your first stay!</p>
            <a href="/listings" class="btn btn-primary">Browse Listings</a>
        </div>
    <% } %>
</div>
